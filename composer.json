    "type": "shopware-platform-plugin",
    "license": "MIT",
    "keywords": [
        "shopware",
        "shopware6",
        "shopware-plugin",
        "indexnow",
        "seo",
        "bing",
        "yandex",
        "indexing"
    ],
    "homepage": "https://stefanpilz.ltd",
    "authors": [
        {
            "name": "Stefan Pilz Ltd.",
            "email": "contact@stefanpilz.ltd",
            "homepage": "https://stefanpilz.ltd",
            "role": "Manufacturer"
        }
    ],
    "support": {
